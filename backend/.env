# ══════════════════════════════════════
# إعدادات بيئة العمل - جامعة الحدباء
# ══════════════════════════════════════

# منفذ السيرفر
PORT=3001

# مفتاح JWT السري (غيّره في الإنتاج!)
JWT_SECRET=hadba_university_secret_key_2024_change_in_production

# مدة صلاحية التوكن
JWT_EXPIRES_IN=24h

# مسار قاعدة البيانات
DB_PATH=./db/university.db

# بيئة العمل: development | production
NODE_ENV=development

# إعدادات CORS - عناوين مسموح لها بالوصول
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
